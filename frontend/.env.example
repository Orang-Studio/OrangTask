# Frontend dev only. In production the frontend is built and served by the
# backend, so the API is same-origin and no variables are required.
#
# During `bun run dev` Vite proxies /api and /ws to the backend (see vite.config.ts),
# so you normally do not need to set anything here.

# Override the API origin only if your backend runs somewhere other than :3001
# VITE_API_URL=http://localhost:3001
